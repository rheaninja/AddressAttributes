<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="sales_order_place_after">
        <observer name="ninja_addressattributes_transfer_quote_values"
                  instance="Ninja\AddressAttributes\Observer\TransferQuoteValuesToOrderAddress"/>
    </event>
    <event name="sales_model_service_quote_submit_success">
        <observer name="ninja_addressattributes_transfer_quote_values_after_submit"
                  instance="Ninja\AddressAttributes\Observer\TransferQuoteValuesToOrderAddress"/>
    </event>
</config>
