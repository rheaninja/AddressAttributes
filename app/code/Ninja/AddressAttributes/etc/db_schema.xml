<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <!-- Attribute Definitions -->
    <table name="ninja_address_attribute" resource="default" engine="innodb" comment="Dynamic Address Attribute Definitions">
        <column xsi:type="int" name="attribute_id" identity="true" nullable="false" unsigned="true" comment="Primary Key"/>
        <column xsi:type="varchar" name="attribute_code" length="100" nullable="false" comment="Unique code"/>
        <column xsi:type="varchar" name="label" length="255" nullable="false" comment="Field label"/>
        <column xsi:type="varchar" name="type" length="50" nullable="false" comment="Input type (text, select, date)"/>
        <column xsi:type="tinyint" name="is_required" nullable="false" default="0" comment="Is Required"/>
        <column xsi:type="int" name="min_length" nullable="true" comment="Minimum Length"/>
        <column xsi:type="int" name="max_length" nullable="true" comment="Maximum Length"/>
        <column xsi:type="text" name="options" nullable="true" comment="JSON encoded options for select/radio"/>
        <column xsi:type="int" name="sort_order" nullable="false" default="0" comment="Sort Order"/>
        <column xsi:type="varchar" name="position" length="50" nullable="false" default="after_shipping_address" comment="Display Position"/>
        <column xsi:type="smallint" name="show_in_grid" nullable="false" default="0" comment="Show in Order Grid"/>
        <column xsi:type="smallint" name="show_in_shipping_address" nullable="false" default="0" comment="Show in Shipping Address"/>
        <column xsi:type="smallint" name="show_in_additional_info" nullable="false" default="0" comment="Show in Additional Info"/>
        <column xsi:type="smallint" name="show_in_invoice" nullable="false" default="0" comment="Show in Admin Invoice"/>
        <column xsi:type="smallint" name="show_in_invoice_pdf" nullable="false" default="0" comment="Show in Invoice PDF"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="attribute_id"/>
        </constraint>
    </table>

    <!-- Attribute Values -->
    <table name="ninja_address_attribute_value" resource="default" engine="innodb" comment="Dynamic Address Attribute Values">
        <column xsi:type="int" name="entity_id" identity="true" nullable="false" unsigned="true" comment="Primary Key"/>
        <column xsi:type="int" name="parent_id" nullable="false" unsigned="true" comment="Quote/Order Address ID"/>
        <column xsi:type="int" name="attribute_id" nullable="false" unsigned="true" comment="Attribute ID"/>
        <column xsi:type="text" name="value" nullable="true" comment="Attribute Value"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="NINJA_ADDRESS_VALUE_PARENT_ID" table="ninja_address_attribute_value" column="parent_id" referenceTable="sales_order_address" referenceColumn="entity_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="NINJA_ADDRESS_VALUE_ATTRIBUTE_ID" table="ninja_address_attribute_value" column="attribute_id" referenceTable="ninja_address_attribute" referenceColumn="attribute_id" onDelete="CASCADE"/>
        <index referenceId="NINJA_ADDRESS_VALUE_PARENT_IDX" indexType="btree">
            <column name="parent_id"/>
        </index>
        <index referenceId="NINJA_ADDRESS_VALUE_ATTRIBUTE_IDX" indexType="btree">
            <column name="attribute_id"/>
        </index>
        <constraint xsi:type="unique" referenceId="NINJA_ADDRESS_VALUE_PARENT_ATTRIBUTE_UNQ">
            <column name="parent_id"/>
            <column name="attribute_id"/>
        </constraint>
    </table>

    <table name="ninja_address_attribute_quote_value" resource="default" engine="innodb" comment="Dynamic Quote Address Attribute Values">
        <column xsi:type="int" name="entity_id" identity="true" nullable="false" unsigned="true" comment="Primary Key"/>
        <column xsi:type="int" name="quote_id" nullable="false" unsigned="true" comment="Quote ID"/>
        <column xsi:type="int" name="attribute_id" nullable="false" unsigned="true" comment="Attribute ID"/>
        <column xsi:type="text" name="value" nullable="true" comment="Attribute Value"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="NINJA_ADDRESS_QUOTE_VALUE_ATTRIBUTE_ID" table="ninja_address_attribute_quote_value" column="attribute_id" referenceTable="ninja_address_attribute" referenceColumn="attribute_id" onDelete="CASCADE"/>
        <index referenceId="NINJA_ADDRESS_QUOTE_VALUE_QUOTE_IDX" indexType="btree">
            <column name="quote_id"/>
        </index>
        <index referenceId="NINJA_ADDRESS_QUOTE_VALUE_ATTRIBUTE_IDX" indexType="btree">
            <column name="attribute_id"/>
        </index>
        <constraint xsi:type="unique" referenceId="NINJA_ADDRESS_QUOTE_VALUE_QUOTE_ATTRIBUTE_UNQ">
            <column name="quote_id"/>
            <column name="attribute_id"/>
        </constraint>
    </table>

    <table name="ninja_address_attribute_store" resource="default" engine="innodb" comment="Dynamic Address Attribute Store Association">
        <column xsi:type="int" name="attribute_id" nullable="false" unsigned="true" comment="Attribute ID"/>
        <column xsi:type="smallint" name="store_id" nullable="false" unsigned="true" comment="Store ID"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="attribute_id"/>
            <column name="store_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="NINJA_ADDRESS_ATTR_STORE_ATTRIBUTE_ID"
                    table="ninja_address_attribute_store"
                    column="attribute_id"
                    referenceTable="ninja_address_attribute"
                    referenceColumn="attribute_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="NINJA_ADDRESS_ATTR_STORE_STORE_ID"
                    table="ninja_address_attribute_store"
                    column="store_id"
                    referenceTable="store"
                    referenceColumn="store_id"
                    onDelete="CASCADE"/>
        <index referenceId="NINJA_ADDRESS_ATTR_STORE_ATTRIBUTE_IDX" indexType="btree">
            <column name="attribute_id"/>
        </index>
        <index referenceId="NINJA_ADDRESS_ATTR_STORE_STORE_IDX" indexType="btree">
            <column name="store_id"/>
        </index>
    </table>
</schema>
