<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">attribute_form.attribute_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Attribute</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="save" class="Ninja\AddressAttributes\Block\Adminhtml\Attribute\Edit\SaveButton"/>
            <button name="delete" class="Ninja\AddressAttributes\Block\Adminhtml\Attribute\Edit\DeleteButton"/>
            <button name="back" class="Ninja\AddressAttributes\Block\Adminhtml\Attribute\Edit\BackButton"/>
        </buttons>
        <namespace>attribute_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>attribute_form.attribute_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="attribute_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="addressattributes/attribute/save"/>
        </settings>
        <dataProvider class="Ninja\AddressAttributes\Ui\Component\DataProvider\AttributeFormDataProvider" name="attribute_form_data_source">
            <settings>
                <requestFieldName>attribute_id</requestFieldName>
                <primaryFieldName>attribute_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general">
        <settings>
            <label/>
        </settings>

        <field name="attribute_id" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">attribute</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>attribute_id</dataScope>
            </settings>
        </field>

        <field name="attribute_code" sortOrder="10" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">attribute</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Code</label>
                <dataScope>attribute_code</dataScope>
            </settings>
        </field>

        <field name="label" sortOrder="20" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">attribute</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Label</label>
                <dataScope>label</dataScope>
            </settings>
        </field>

        <field name="type" sortOrder="30" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">attribute</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Type</label>
                <dataScope>type</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Ninja\AddressAttributes\Model\Attribute\TypeOptions"/>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="options" sortOrder="35" formElement="input"
               component="Ninja_AddressAttributes/js/form/element/select-options-grid"
               template="ui/form/field">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">attribute</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Options</label>
                <dataScope>options</dataScope>
                <visible>true</visible>
                <elementTmpl>Ninja_AddressAttributes/form/element/select-options-grid</elementTmpl>
            </settings>
        </field>

        <field name="is_required" sortOrder="40" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">attribute</item>
                    <item name="default" xsi:type="number">0</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Required</label>
                <dataScope>is_required</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
    </fieldset>

</form>
