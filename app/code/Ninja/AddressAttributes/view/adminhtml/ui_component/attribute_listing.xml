<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd" name="attribute_listing">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">attribute_listing.attribute_listing_data_source</item>
            <item name="deps" xsi:type="string">attribute_listing.attribute_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label>Add New Attribute</label>
            </button>
        </buttons>
        <spinner>attribute_columns</spinner>
        <deps>
            <dep>attribute_listing.attribute_listing_data_source</dep>
        </deps>
    </settings>
        <dataSource name="attribute_listing_data_source" component="Magento_Ui/js/grid/provider">
            <settings>
                <storageConfig>
                    <param name="indexField" xsi:type="string">attribute_id</param>
                </storageConfig>
                <updateUrl path="mui/index/render"/>
            </settings>
            <dataProvider class="Ninja\AddressAttributes\Ui\Component\DataProvider\AttributeDataProvider" name="attribute_listing_data_source">
                <settings>
                    <requestFieldName>attribute_id</requestFieldName>
                    <primaryFieldName>attribute_id</primaryFieldName>
                </settings>
            </dataProvider>
        </dataSource>
        <columns name="attribute_columns">
            <selectionsColumn name="ids">
                <settings>
                    <indexField>attribute_id</indexField>
                </settings>
            </selectionsColumn>
            <column name="attribute_id">
                <settings>
                    <filter>text</filter>
                    <label>Attribute ID</label>
                </settings>
            </column>
            <column name="attribute_code">
                <settings>
                    <filter>text</filter>
                    <label>Code</label>
                </settings>
            </column>
            <column name="label">
                <settings>
                    <filter>text</filter>
                    <label>Label</label>
                </settings>
            </column>
            <column name="type">
                <settings>
                    <filter>text</filter>
                    <label>Type</label>
                </settings>
            </column>
            <column name="is_required">
                <settings>
                    <filter>select</filter>
                    <label>Required</label>
                    <options>
                        <option name="0" xsi:type="array">
                            <item name="value" xsi:type="string">0</item>
                            <item name="label" xsi:type="string">No</item>
                        </option>
                        <option name="1" xsi:type="array">
                            <item name="value" xsi:type="string">1</item>
                            <item name="label" xsi:type="string">Yes</item>
                        </option>
                    </options>
                </settings>
            </column>
            <actionsColumn name="actions" class="Ninja\AddressAttributes\Ui\Component\Listing\Column\AttributeActions">
                <settings>
                    <indexField>attribute_id</indexField>
                </settings>
            </actionsColumn>
        </columns>
    </listing>
